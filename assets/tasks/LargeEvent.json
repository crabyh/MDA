{
    "task": [
        {
            "name": "LargeEvent",
            "label": "$task.LargeEvent.label",
            "entry": "LargeEventMain",
            "description": "$task.LargeEvent.description",
            "option": [
                "LargeEventTheme",
                "LargeEventStoryPriority",
                "LargeEventLoginStamp",
                "LargeEventChallenge",
                "LargeEventStory",
                "LargeEventMission"
            ],
            "group": [
                "periodic"
            ]
        }
    ],
    "option": {
        "LargeEventTheme": {
            "type": "select",
            "default_case": "WaveToYou",
            "label": "$option.LargeEventTheme.label",
            "cases": [
                {
                    "name": "ArkRanger",
                    "label": "$option.LargeEventTheme.ArkRanger",
                    "option": [
                        "LargeEventArkRangerMiniGame"
                    ],
                    "pipeline_override": {
                        "LargeEventEnterMainPage": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "LargeEvent/ArkRanger/ArkRangerLogo.png"
                                    ]
                                }
                            }
                        },
                        "LargeEventClickStoryStage": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "LargeEvent/ArkRanger/ArkRangerStory1Stage.png",
                                        "LargeEvent/ArkRanger/ArkRangerStory2StageNormal.png",
                                        "LargeEvent/ArkRanger/ArkRangerStory2StageHard.png"
                                    ]
                                }
                            }
                        },
                        "LargeEventClickStoryStageRepeatable": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "LargeEvent/ArkRanger/ArkRangerStory1StageRepeatable.png",
                                        "LargeEvent/ArkRanger/ArkRangerStory2StageNormalRepeatable.png",
                                        "LargeEvent/ArkRanger/ArkRangerStory2StageHardRepeatable.png"
                                    ]
                                }
                            }
                        },
                        "LargeEventMissionClaimed": {
                            "recognition": {
                                "param": {
                                    "lower": [
                                        15,
                                        25,
                                        55
                                    ],
                                    "upper": [
                                        35,
                                        35,
                                        65
                                    ],
                                    "count": 50
                                }
                            }
                        }
                    }
                },
                {
                    "name": "StarAnis",
                    "label": "$option.LargeEventTheme.StarAnis",
                    "option": [
                        "LargeEventStarAnisMerchBagClick"
                    ],
                    "pipeline_override": {
                        "LargeEventEnterMainPage": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "LargeEvent/StarAnis/StarAnisLogo.png"
                                    ]
                                }
                            }
                        },
                        "LargeEventClickStoryStage": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "LargeEvent/StarAnis/StarAnisStory1Stage.png",
                                        "LargeEvent/StarAnis/StarAnisStory2StageNormal.png",
                                        "LargeEvent/StarAnis/StarAnisStory2StageHard.png",
                                        "LargeEvent/StarAnis/StarAnisStory2StageHardSP.png"
                                    ]
                                }
                            }
                        },
                        "LargeEventClickStoryStageRepeatable": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "LargeEvent/StarAnis/StarAnisStory1StageRepeatable.png",
                                        "LargeEvent/StarAnis/StarAnisStory2StageNormal.png",
                                        "LargeEvent/StarAnis/StarAnisStory2StageHardRepeatable.png"
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "WaveToYou",
                    "label": "$option.LargeEventTheme.WaveToYou",
                    "option": [
                        "LargeEventWaveToYouMiniGame"
                    ],
                    "pipeline_override": {
                        "LargeEventEnterMainPage": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "LargeEvent/WaveToYou/WaveToYouLogo.png"
                                    ]
                                }
                            }
                        },
                        "LargeEventClickStoryStage": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "LargeEvent/WaveToYou/WaveToYouStory1Stage.png",
                                        "LargeEvent/WaveToYou/WaveToYouStory2StageNormal.png"
                                    ]
                                }
                            }
                        },
                        "LargeEventClickStoryStageRepeatable": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "LargeEvent/WaveToYou/WaveToYouStory1StageRepeatable.png",
                                        "LargeEvent/WaveToYou/WaveToYouStory2StageNormalRepeatable.png"
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "Other",
                    "label": "$option.LargeEventTheme.Other"
                }
            ]
        },
        "LargeEventArkRangerMiniGame": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.LargeEventArkRangerMiniGame.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "LargeEventMainPageFlow": {
                            "next": [
                                "[JumpBack]LargeEventEnterLoginStamp",
                                "[JumpBack]LargeEventEnterChallenge",
                                "[JumpBack]LargeEventEnterStory",
                                "[JumpBack]LargeEventEnterMission",
                                "[JumpBack]LargeEventArkRangerMiniGame",
                                "CommonEndTask"
                            ]
                        }
                    }
                },
                {
                    "name": "No"
                }
            ]
        },
        "LargeEventWaveToYouMiniGame": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.LargeEventWaveToYouMiniGame.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "LargeEventMainPageFlow": {
                            "next": [
                                "[JumpBack]LargeEventEnterLoginStamp",
                                "[JumpBack]LargeEventEnterChallenge",
                                "[JumpBack]LargeEventEnterStory",
                                "[JumpBack]LargeEventEnterMission",
                                "[JumpBack]LargeEventWaveToYouMiniGame",
                                "CommonEndTask"
                            ]
                        }
                    }
                },
                {
                    "name": "No"
                }
            ]
        },
        "LargeEventLoginStamp": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.LargeEventContent.LargeEventLoginStamp",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "LargeEventEnterLoginStamp": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "LargeEventEnterLoginStamp": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "LargeEventChallenge": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.LargeEventContent.LargeEventChallenge",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "LargeEventEnterChallenge": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "LargeEventEnterChallenge": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "LargeEventStory": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.LargeEventContent.LargeEventStory",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "LargeEventEnterStory": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "LargeEventEnterStory": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "LargeEventMission": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.LargeEventContent.LargeEventMission",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "LargeEventEnterMission": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "LargeEventEnterMission": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "LargeEventStarAnisMerchBagClick": {
            "type": "switch",
            "default_case": "Yes",
            "label": "$option.LargeEventStarAnisMerchBagClick.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "LargeEventMainPageFlow": {
                            "next": [
                                "[JumpBack]LargeEventEnterLoginStamp",
                                "[JumpBack]LargeEventEnterChallenge",
                                "[JumpBack]LargeEventEnterStory",
                                "[JumpBack]LargeEventEnterMission",
                                "[JumpBack]LargeEventStarAnisClickMerchBag",
                                "CommonEndTask"
                            ]
                        }
                    }
                },
                {
                    "name": "No"
                }
            ]
        },
        "LargeEventStoryPriority": {
            "type": "select",
            "default_case": "Story2First",
            "label": "$option.LargeEventStoryPriority.label",
            "cases": [
                {
                    "name": "Story2First",
                    "label": "$option.LargeEventStoryPriority.Story2First",
                    "pipeline_override": {
                        "LargeEventEnterStory": {
                            "recognition": {
                                "param": {
                                    "index": -1
                                }
                            }
                        }
                    }
                },
                {
                    "name": "Story1First",
                    "label": "$option.LargeEventStoryPriority.Story1First"
                }
            ]
        }
    }
}
