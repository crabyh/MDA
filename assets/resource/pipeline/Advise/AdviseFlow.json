                    30
                ],
                "upper": [
                    255,
                    80,
                    80
                ],
                "count": 10
            }
        }
    },
    "AdviseCollectionCompletedFlow": {
        "desc": "咨询日志收集完成流程",
        "recognition": {
            "type": "And",
            "param": {
