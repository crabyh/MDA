{
    "AdviseFlow": {
        "desc": "开始咨询流程",
        "next": [
            "AdviseAttemptsExhausted",
            "AdviseCurrentTargetCompletedFlow",
            "AdviseCollectionCompletedFlow",
            "AdviseCollectionNotCompletedFlow"
        ]
    },
    "AdviseAttemptsExhausted": {
        "desc": "次数耗尽",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "AdviseGrayButtonVisible",
                    "Advise0AttemptsVisible"
                ]
            }
        }
    },
    "AdviseGrayButtonVisible": {
        "desc": "按钮变灰",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    647,
                    567,
                    155,
                    53
                ],
                "lower": [
                    100,
                    100,
                    100
                ],
                "upper": [
                    180,
                    180,
                    180
                ],
                "count": 500
            }
        }
    },
    "AdviseQuickAdviseGrayButtonVisible": {
        "desc": "快速咨询按钮变灰",
        "recognition": {
            "type": "ColorMatch",
            "param": {
